# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth - GitHub OAuth
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# NextAuth.js
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Auth - Atlassian OAuth (Phase 3)
# Create at: https://developer.atlassian.com/console/myapps/
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
# 32-byte hex key for token encryption (64 hex characters)
# Generate with: openssl rand -hex 32
ATLASSIAN_ENCRYPTION_KEY=

# AI - Anthropic
# Get at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Database - Turso
# Create at: https://turso.tech/
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Admin Config (Pre-configured defaults)
CONFLUENCE_SPACE_KEY=
CONFLUENCE_PARENT_PAGE_ID=
JIRA_PROJECT_KEY=
JIRA_ISSUE_TYPE=Story
